}

script:pre-request {
  const btoa = require("btoa");
  const prov_id = bru.getEnvVar("PROV_ID");
  
  req.setHeader("x-api-key", bru.getEnvVar("PROVIDER_IH_APIKEY"));
}

settings {
  encodeUrl: true
  timeout: 0
}

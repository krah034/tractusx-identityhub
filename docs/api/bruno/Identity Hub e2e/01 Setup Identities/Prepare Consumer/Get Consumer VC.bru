meta {
  name: Get Consumer VC
  type: http
  seq: 6
}

get {
  url: {{CONSUMER_IDHUB_ID_API}}/v1alpha/participants/{{CONS_ID}}/credentials
  body: json
  auth: none
}

headers {
  x-api-key: {{CONSUMER_IH_APIKEY}}
}

script:pre-request {
  
  req.setHeader("x-api-key", bru.getEnvVar("CONSUMER_IH_APIKEY"));
}

settings {
  encodeUrl: true
  timeout: 0
}

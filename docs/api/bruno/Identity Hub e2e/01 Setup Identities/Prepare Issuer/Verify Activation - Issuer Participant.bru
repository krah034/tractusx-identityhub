meta {
  name: Verify Activation - Issuer Participant
  type: http
  seq: 3
}

get {
  url: {{ISSUER_ID_API}}/v1alpha/participants/{{ISS_ID}}
  body: json
  auth: inherit
}

headers {
  x-api-key: {{ISSUER_APIKEY}}
}

script:pre-request {
}

script:post-response {
  const apiKey = res.getBody().apiKey.trim();
  if (apiKey) {
    bru.setEnvVar("ISSUER_APIKEY", apiKey);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
